{
  "name": "birds",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "WebXR bird-flight simulator — hands shape the wings. Vanilla Three.js + Vite + TypeScript.",
  "engines": {
    "node": ">=20.19 || >=22.12"
  },
  "scripts": {
    "dev": "vite",
    "dev:5174": "vite --port 5174 --strictPort",
    "dev:https": "cross-env VITE_HTTPS=1 vite",
    "dev:https:5174": "cross-env VITE_HTTPS=1 vite --port 5174 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "3d-tiles-renderer": "^0.4.28",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  }
}
